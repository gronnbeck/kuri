#!/usr/bin/env ruby
# frozen_string_literal: true

require "yaml"
require "fileutils"
require "digest"

ROOT        = Dir.pwd
CONFIG_FILE = File.join(ROOT, ".jijitsu.yml")
SUMS_FILE   = File.join(ROOT, ".jijitsu", "checksums.yml")

abort "Error: .jijitsu.yml not found in #{ROOT}" unless File.exist?(CONFIG_FILE)

config = YAML.load_file(CONFIG_FILE)

spec_file        = File.join(ROOT, config["spec"]             || "spec.md")
docs_dir         = File.join(ROOT, config["docs_dir"]         || ".jijitsu/docs")
prompt_file      = File.join(ROOT, config["system_prompt"]    || ".jijitsu/jitsu.md")
implement_file   = File.join(ROOT, config["implement_prompt"] || ".jijitsu/implement.md")
process_file     = File.join(ROOT, config["process"]          || ".jijitsu/process.md")
interval         = (config["interval"] || 60).to_i
once             = ARGV.include?("--once")

abort "Error: system prompt not found: #{prompt_file}" unless File.exist?(prompt_file)
abort "Error: implement prompt not found: #{implement_file}" unless File.exist?(implement_file)

FileUtils.mkdir_p(docs_dir)

system_prompt    = File.read(prompt_file)
implement_prompt = File.read(implement_file)

def run_claude(prompt)
  IO.popen(%w[claude --print --dangerously-skip-permissions], "r+") do |io|
    io.write(prompt)
    io.close_write
    io.each_line { |line| print line }
  end
end

def ts
  Time.now.strftime("%H:%M:%S")
end

def md5(path)
  Digest::MD5.file(path).hexdigest
end

def load_sums(sums_file)
  File.exist?(sums_file) ? YAML.load_file(sums_file) || {} : {}
end

def save_sum(sums_file, key, path)
  sums = load_sums(sums_file)
  sums[key] = md5(path)
  File.write(sums_file, sums.to_yaml)
end

def changed?(sums_file, key, path)
  return true unless File.exist?(path)
  load_sums(sums_file)[key] != md5(path)
end

def spec_cycle(spec_file, docs_dir, system_prompt, config, sums_file)
  unless File.exist?(spec_file)
    warn "[#{ts}] #{config["spec"]} not found — skipping spec cycle."
    return
  end

  unless changed?(sums_file, "spec", spec_file)
    puts "[#{ts}] Spec cycle — no changes, skipping."
    return
  end

  puts "[#{ts}] Spec cycle — processing #{config["spec"]}..."

  prompt = <<~PROMPT
    #{system_prompt}

    ---

    Main spec file path: #{spec_file}
    Docs directory: #{docs_dir}

    Current contents of the main spec:

    #{File.read(spec_file)}

    Process the spec now. Read any existing linked docs in #{docs_dir} before writing, so you can diff and update incrementally.
  PROMPT

  run_claude(prompt)
  save_sum(sums_file, "spec", spec_file)
  git_commit_docs(spec_file, docs_dir)
end

def git_commit_docs(spec_file, docs_dir)
  staged = `git -C #{ROOT} add --dry-run #{spec_file} #{docs_dir} 2>/dev/null`.strip
  return if staged.empty?

  system("git", "-C", ROOT, "add", spec_file, docs_dir, SUMS_FILE)
  diff = `git -C #{ROOT} diff --cached --name-only`.strip
  return if diff.empty?

  puts "[#{ts}] Committing doc changes..."
  system("git", "-C", ROOT, "commit", "-m", "jijitsu: update spec docs [auto]")
end

def implement_cycle(docs_dir, implement_prompt, process_file, sums_file)
  tasks_file = File.join(docs_dir, "tasks.md")

  unless File.exist?(tasks_file)
    puts "[#{ts}] Implement cycle — no tasks.md yet, skipping."
    return
  end

  unless changed?(sums_file, "tasks", tasks_file)
    puts "[#{ts}] Implement cycle — no changes, skipping."
    return
  end

  process_guide = File.exist?(process_file) ? File.read(process_file) : ""

  puts "[#{ts}] Implement cycle — picking up next task..."

  prompt = <<~PROMPT
    #{implement_prompt}

    ---

    Tasks file: #{tasks_file}
    Development process guide:

    #{process_guide}

    Implement the next task now.
  PROMPT

  run_claude(prompt)
  save_sum(sums_file, "tasks", tasks_file)
end

if once
  puts "Jijitsu — running once on #{config["spec"]}."
else
  puts "Jijitsu — watching #{config["spec"]} every #{interval}s. Ctrl+C to stop."
end
puts

if once
  spec_cycle(spec_file, docs_dir, system_prompt, config, SUMS_FILE)
  implement_cycle(docs_dir, implement_prompt, process_file, SUMS_FILE)
  puts "[#{ts}] Done."
else
  loop do
    spec_cycle(spec_file, docs_dir, system_prompt, config, SUMS_FILE)
    implement_cycle(docs_dir, implement_prompt, process_file, SUMS_FILE)
    puts "[#{ts}] Done. Sleeping #{interval}s...\n\n"
    sleep interval
  rescue Interrupt
    puts "\nStopped."
    exit 0
  end
end
