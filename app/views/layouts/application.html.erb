<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Kuri" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Kuri">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="sidebar">
      <div class="sidebar-logo"><%= link_to "Kuri", root_path %></div>
      <ul>
        <li><%= link_to "Practice", practice_path %></li>
        <li><%= link_to "Notes", notes_path %></li>
        <li><%= link_to "Decks", decks_path %></li>
      </ul>
    </nav>
    <main class="main-content">
      <% flash.each do |type, message| %>
        <p class="flash flash--<%= type %>"><%= message %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
